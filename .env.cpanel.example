# ===========================================
# TELEGRAM BOT CONFIGURATION FOR CPANEL
# ===========================================

# Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram User ID (get from @userinfobot)
ADMIN_USER_ID=your_telegram_user_id_here

# ===========================================
# CPANEL HOSTING CONFIGURATION
# ===========================================

# Your full cPanel bot URL (REQUIRED for webhook setup)
# Example: https://checkresultbot.abdulaki.com or https://checkresultbot.abdulaki.com
BOT_BASE_URL=https://checkresultbot.abdulaki.com

# Your cPanel domain only (extracted from BOT_BASE_URL if not set)
CPANEL_DOMAIN=checkresultbot.abdulaki.com

# Protocol (http or https) - Telegram requires HTTPS for production
PROTOCOL=http

# Bot path on your domain (leave empty if bot is at root)
BOT_PATH=

# Base path for Express app (usually same as BOT_PATH)
BASE_PATH=

# Webhook endpoint path (default: /webhook)
WEBHOOK_PATH=/webhook

# Environment (set to production for cPanel)
NODE_ENV=production

# Port (cPanel assigns automatically, but you can specify)
PORT=3000

# ===========================================
# CPANEL MYSQL DATABASE CONFIGURATION
# ===========================================

# Database host (usually localhost for cPanel)
DB_HOST=localhost

# Database port (usually 3306 for MySQL)
DB_PORT=3306

# Database name (usually prefixed with your cPanel username)
# Example: username_student_results
DB_NAME=your_cpanel_db_name

# Database user (usually prefixed with your cPanel username)
# Example: username_botuser
DB_USER=your_cpanel_db_user

# Database password
DB_PASSWORD=your_cpanel_db_password

# ===========================================
# STORAGE CONFIGURATION
# ===========================================

# Use JSON file storage instead of MySQL (true/false)
# Set to false for production with MySQL
USE_JSON_STORAGE=false

# JSON file path (if using JSON storage)
JSON_FILE_PATH=./data/students.json

# ===========================================
# CPANEL SPECIFIC SETTINGS
# ===========================================

# File upload limits (adjust based on your cPanel limits)
MAX_FILE_SIZE=50mb

# Temp directory for file processing
TEMP_DIR=./temp

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ===========================================
# WEBHOOK CONFIGURATION
# ===========================================

# Full webhook URL (auto-generated from BOT_BASE_URL + WEBHOOK_PATH)
# WEBHOOK_URL=https://checkresultbot.abdulaki.com/webhook

# Custom webhook secret (for additional security)
# WEBHOOK_SECRET=your_custom_secret_here

# ===========================================
# OPTIONAL ADVANCED SETTINGS
# ===========================================

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Maximum concurrent file processing
MAX_CONCURRENT_UPLOADS=3

# Bot status endpoints
STATUS_ENDPOINT=/status
HEALTH_ENDPOINT=/health

# ===========================================
# EXAMPLE CONFIGURATION FOR YOUR DOMAIN
# ===========================================
# 
# For checkresultbot.abdulaki.com, your .env should look like:
#
# BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# ADMIN_USER_ID=123456789
# BOT_BASE_URL=https://checkresultbot.abdulaki.com
# CPANEL_DOMAIN=checkresultbot.abdulaki.com
# PROTOCOL=http
# BOT_PATH=
# WEBHOOK_PATH=/webhook
# NODE_ENV=production
# DB_HOST=localhost
# DB_NAME=myuser_student_results
# DB_USER=myuser_botuser
# DB_PASSWORD=secure_password_123
# USE_JSON_STORAGE=false
#
# This will create these URLs:
# - Bot Home: https://checkresultbot.abdulaki.com/
# - Webhook: https://checkresultbot.abdulaki.com/webhook
# - Status: https://checkresultbot.abdulaki.com/status
# - Health: https://checkresultbot.abdulaki.com/health
#
# ===========================================

# ===========================================
# EXAMPLE CPANEL CONFIGURATION
# ===========================================
# 
# For a typical cPanel setup, your .env should look like:
#
# BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# ADMIN_USER_ID=123456789
# CPANEL_DOMAIN=mystudentbot.com
# BOT_PATH=/telegram-bot
# NODE_ENV=production
# DB_HOST=localhost
# DB_NAME=myuser_student_results
# DB_USER=myuser_botuser
# DB_PASSWORD=secure_password_123
# USE_JSON_STORAGE=false
#
# ===========================================

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
#
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Upload to your cPanel telegram-bot folder
# 4. Run: node setup-database.js
# 5. Run: CPANEL_DOMAIN=yourdomain.com node setup-webhook-cpanel.js
# 6. Start your bot: node app.js
#
# ===========================================